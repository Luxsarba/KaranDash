  beforeQuestDialogue:
    name: Quest Tester
    email: quest@test.local
    recipientName: Player
    portrait: {fileID: 0}
    sentences:
    - "\u041F\u0440\u0438\u043D\u0435\u0441\u0438 \u043C\u043D\u0435 Quest Pass \u0438\u0437
      \u043D\u0430\u0447\u0430\u043B\u0430 \u0434\u043E\u0440\u043E\u0436\u043A\u0438."
    - "\u041F\u043E\u0441\u043B\u0435 \u0441\u0434\u0430\u0447\u0438 \u044F \u0432\u044B\u0434\u0430\u043C
      Cuban \u0438 \u0432\u043A\u043B\u044E\u0447\u0443 \u043C\u0430\u0440\u043A\u0435\u0440
      \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u044F."
  waitingDialogue:
    name: Quest Tester
    email: quest@test.local
    recipientName: Player
    portrait: {fileID: 0}
    sentences:
    - "\u0423 \u0442\u0435\u0431\u044F \u0435\u0449\u0451 \u043D\u0435\u0442 Quest
      Pass."
    - "\u041F\u043E\u0434\u0431\u0435\u0440\u0438 \u0435\u0433\u043E \u043D\u0430
      \u043F\u0435\u0440\u0432\u043E\u043C \u0448\u0430\u0433\u0435 \u0434\u043E\u0440\u043E\u0436\u043A\u0438
      \u0438 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0439\u0441\u044F."
  completedDialogue:
    name: Quest Tester
    email: quest@test.local
    recipientName: Player
    portrait: {fileID: 0}
    sentences:
    - "\u041A\u0432\u0435\u0441\u0442 \u0441\u0434\u0430\u043D."
    - "\u041D\u0430\u0433\u0440\u0430\u0434\u0430 \u0432\u044B\u0434\u0430\u043D\u0430,
      \u043C\u0430\u0440\u043A\u0435\u0440 \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u044F
