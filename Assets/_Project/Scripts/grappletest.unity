  afterCompletedDialogue:
    name: Quest Tester
    email: quest@test.local
    recipientName: Player
    portrait: {fileID: 0}
    sentences:
    - "\u042D\u0442\u043E\u0442 \u043A\u0432\u0435\u0441\u0442 \u0443\u0436\u0435
      \u0437\u0430\u0432\u0435\u0440\u0448\u0451\u043D."
    - "\u041F\u0440\u043E\u0432\u0435\u0440\u043A\u0430 post-complete \u0434\u0438\u0430\u043B\u043E\u0433\u0430
      \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442."
