  m_Script: {fileID: 11500000, guid: bb70ad2334bf9cd40b99ff5a17311249, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    name: "\u0421\u0442\u0430\u0440\u0435\u0439\u0448\u0438\u043D\u0430 4"
    email: elder4
    recipientName: "\u0418\u0433\u0440\u043E\u043A"
    portrait: {fileID: 0}
    sentences:
    - "\u041D\u0443\u0436\u043D\u043E \u0432\u044B\u0431\u0440\u0430\u0442\u044C\u0441\u044F
      \u043E\u0442\u0441\u044E\u0434\u0430, \u0434\u0435\u0440\u0436\u0438 \u0440\u0443\u043B\u0435\u0442\u043A\u0443,
      \u0441 \u0435\u0435 \u043F\u043E\u043C\u043E\u0449\u044C\u044E, \u0442\u044B
      \u0441\u043C\u043E\u0436\u0435\u0448\u044C \u0432\u0437\u043E\u0431\u0440\u0430\u0442\u044C\u0441\u044F
      \u043D\u0430 \u0442\u0435 \u0432\u0435\u0440\u0448\u0438\u043D\u044B."
    - "\u041E\u043D\u0430 \u0442\u0435\u0431\u0435 \u0435\u0449\u0451 \u043F\u0440\u0438\u0433\u043E\u0434\u0438\u0442\u0441\u044F.
      \u0423\u0434\u0430\u0447\u0438!"
