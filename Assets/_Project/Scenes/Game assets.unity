--- !u!114 &1500764207
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1500764206}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d2b1470d4cecf4b4485bb8b023857da8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  requiredItem: {fileID: 11400000, guid: 85585743436843148b4f31548bbad001, type: 2}
  persistentStateId: {fileID: 1500764209}
  beforeQuestDialogue:
    name: "\u0421\u0442\u0430\u0440\u0435\u0439\u0448\u0438\u043D\u0430 2"
    email: elder2
    recipientName: "\u0418\u0433\u0440\u043E\u043A"
    portrait: {fileID: 0}
    sentences:
    - "\u0427\u0442\u043E\u0431\u044B \u0434\u043E\u0441\u0442\u0430\u0442\u044C
      \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442, \u043D\u0443\u0436\u043D\u043E
      \u043E\u0434\u043E\u043B\u0435\u0442\u044C 12 \u043B\u0430\u0441\u0442\u0438\u043A\u043E\u0432."
    - "\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0439\u0441\u044F \u043A\u043E
      \u043C\u043D\u0435, \u043A\u043E\u0433\u0434\u0430 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0448\u044C."
  waitingDialogue:
    name: "\u0421\u0442\u0430\u0440\u0435\u0439\u0448\u0438\u043D\u0430 2"
    email: elder2
    recipientName: "\u0418\u0433\u0440\u043E\u043A"
    portrait: {fileID: 0}
    sentences:
    - "\u0421\u0447\u0451\u0442 \u0435\u0449\u0451 \u043D\u0435 \u0437\u0430\u043A\u0440\u044B\u0442.
      \u0423\u043D\u0438\u0447\u0442\u043E\u0436\u044C 12 \u043B\u0430\u0441\u0442\u0438\u043A\u043E\u0432
      \u0438 \u0432\u0435\u0440\u043D\u0438\u0441\u044C."
  completedDialogue:
    name: "\u0421\u0442\u0430\u0440\u0435\u0439\u0448\u0438\u043D\u0430 2"
    email: elder2
    recipientName: "\u0418\u0433\u0440\u043E\u043A"
    portrait: {fileID: 0}
    sentences:
    - "\u0422\u044B \u0441\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F. \u0417\u0430\u0431\u0438\u0440\u0430\u0439
      \u0432\u0442\u043E\u0440\u043E\u0439 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442."
  afterCompletedDialogue:
    name: "\u0421\u0442\u0430\u0440\u0435\u0439\u0448\u0438\u043D\u0430 2"
    email: elder2
    recipientName: "\u0418\u0433\u0440\u043E\u043A"
    portrait: {fileID: 0}
    sentences:
    - "\u041B\u0430\u0441\u0442\u0438\u043A\u0438 \u0443\u0436\u0435 \u043F\u043E\u0431\u0435\u0436\u0434\u0435\u043D\u044B.
      \u0418\u0449\u0438 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442."
  onCompleteActions: {fileID: 1500764208}
