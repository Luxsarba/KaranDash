--- !u!114 &612430748
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 612430746}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fba0c9e8bf77f904b963cda244714fcb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  noteTitle: "\u0421\u043A\u043B\u0430\u0434"
  noteSubtitle: "\u041F\u0430\u0442\u0442\u0435\u0440\u043D \u0440\u044B\u0447\u0430\u0433\u043E\u0432"
  noteText: "\u041F\u0430\u0442\u0442\u0435\u0440\u043D \u043D\u0430 \u0442\u0440\u0438
    \u0440\u044B\u0447\u0430\u0433\u0430 \u0441\u043E\u0431\u0440\u0430\u043D \u043A\u0430\u043A
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0430\u044F multi-lock \u0434\u0432\u0435\u0440\u044C:
    \u043A\u0430\u0436\u0434\u044B\u0439 lever \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E
    \u043E\u0442\u0432\u043E\u0434\u0438\u0442 \u0441\u0432\u043E\u044E \u043F\u0435\u0440\u0435\u043A\u043B\u0430\u0434\u0438\u043D\u0443.
    \u0422\u0430\u043A \u044D\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
    \u0431\u0435\u0437 \u043D\u043E\u0432\u043E\u0433\u043E \u0430\u0433\u0440\u0435\u0433\u0430\u0442\u043E\u0440\u0430
    \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0439."
  backgroundSprite: {fileID: 0}
