  m_EditorClassIdentifier: 
  noteTitle: "\u0424\u0438\u043D\u0430\u043B"
  noteSubtitle: "\u0412\u0438\u0434\u0435\u043E placeholder"
  noteText: "\u0424\u0438\u043D\u0430\u043B\u044C\u043D\u0430\u044F \u0440\u0430\u043C\u043A\u0430
    \u0443\u0436\u0435 \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u0435\u0442 \u043F\u043E\u043B\u043D\u044B\u0439
    \u043D\u0430\u0431\u043E\u0440 \u0438\u0437 6 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u043E\u0432
    \u0438 \u0437\u0430\u043F\u0443\u0441\u043A\u0430\u0435\u0442 cutscene overlay.
    \u0414\u043B\u044F \u043F\u043E\u043B\u043D\u043E\u0433\u043E \u043F\u0440\u043E\u0433\u043E\u043D\u0430
