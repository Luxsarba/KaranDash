--- !u!114 &7589668994265377160
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7589668994265377159}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d2b1470d4cecf4b4485bb8b023857da8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  requiredItem: {fileID: 11400000, guid: b87a444571e114e4aac745d1b643eade, type: 2}
  beforeQuestDialogue:
    name: "\u0412\u043E\u0440\u0447\u0443\u043D-\u041C\u043E\u0441\u0442\u043E\u0432\u043E\u0439"
    email: ' '
    recipientName: "\u0414\u0430\u0448\u0430"
    portrait: {fileID: 21300000, guid: d17e3519d4a943742bc3774091741685, type: 3}
    sentences:
    - "\u042D\u0439, \u043F\u0430\u0440\u0435\u043D\u044C, \u0435\u0441\u043B\u0438
      \u0437\u0430\u0445\u043E\u0447\u0435\u0448\u044C \u043F\u043E\u043F\u0430\u0441\u0442\u044C
      \u043D\u0430 \u0442\u0443 \u0441\u0442\u043E\u0440\u043E\u043D\u0443, \u043F\u0440\u0438\u043D\u0435\u0441\u0438
      \u043C\u043D\u0435 \u0438\u0437\u043E\u043B\u0435\u043D\u0442\u0443, \u043E\u043D\u0430
      \u0432\u043E\u043D \u0442\u0430\u043C, \u043F\u043E\u0437\u0430\u0434\u0438
      \u0442\u0435\u0431\u044F. "
    - "\u041A\u0441\u0442\u0430\u0442\u0438, \u0440\u0435\u0431\u044F\u0442\u043D\u044F
      \u0441\u043A\u0430\u0437\u0430\u043B\u0438, \u0442\u043E \u0442\u044B \u0432
      \u0438\u0445 \u0438\u0433\u0440\u0435 \u0432 \u043F\u0440\u044F\u0442\u043A\u0438
      \u0432\u043E\u0434\u0438\u0448\u044C, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
      \u0438\u0434\u0438 \u043F\u043E\u0438\u0449\u0438 \u0438\u0445."
  waitingDialogue:
    name: "\u0412\u043E\u0440\u0447\u0443\u043D-\u041C\u043E\u0441\u0442\u043E\u0432\u043E\u0439"
    email: ' '
    recipientName: "\u041A\u0430\u0440\u0430\u043D\u0434\u0430\u0448\u0443\u043B\u0438\u043A"
    portrait: {fileID: 0}
    sentences:
    - "\u0418 \u0434\u043E\u043B\u0433\u043E \u043C\u043D\u0435 \u0435\u0449\u0435
      \u0442\u0435\u0431\u044F \u0436\u0434\u0430\u0442\u044C?"
    - "\u0414\u0430\u0432\u0430\u0439 \u043F\u043E\u0431\u044B\u0441\u0442\u0440\u0435\u0435."
  completedDialogue:
    name: "\u0412\u043E\u0440\u0447\u0443\u043D-\u041C\u043E\u0441\u0442\u043E\u0432\u043E\u0439"
    email: 
    recipientName: "\u041A\u0430\u0440\u0430\u043D\u0434\u0430\u0448\u0443\u043B\u0438\u043A"
    portrait: {fileID: 0}
    sentences:
    - "\u0412\u043E\u0442 \u043C\u043E\u043B\u043E\u0434\u0435\u0446, \u043F\u0440\u043E\u0445\u043E\u0434\u0438
      \u043D\u0430 \u0442\u0443 \u0441\u0442\u043E\u0440\u043E\u043D\u0443 \u0435\u0441\u043B\u0438
      \u0445\u043E\u0447\u0435\u0448\u044C"
  onCompleteActions: {fileID: 7589668994265377161}
